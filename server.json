{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.rafaelcg/stripekit",
  "description": "Reconcile a declarative Stripe catalog and inspect your account — plan, push, pull, check.",
  "repository": {
    "url": "https://github.com/rafaelcg/stripekit",
    "source": "github"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "stripekit",
      "version": "0.2.1",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [{ "type": "positional", "value": "mcp" }]
    }
  ]
}
